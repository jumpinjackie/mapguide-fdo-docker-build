    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch FDO Core Unit Test Suite",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/user/build_area/fdo/Fdo/UnitTest/UnitTest",
            "args": [],
            "stopAtEntry": false,
            "cwd": "/home/user/build_area/fdo/Fdo/UnitTest",
            "environment": [
                {
                    "name": "NLSPATH",
                    "value": "/home/user/build_area/fdo/nls/linux/en_US/%N"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
